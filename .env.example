MONGO_URI=mongodb://mongo:27017/nexTalent
GROQ_API_KEY=your_groq_api_key_here
AUTONOMOUS_AGENT_VERBOSE=true

# Empty values use local persistent Chroma at data/chroma.
# Set these in Cloud Run or GCP jobs when they must connect to a remote Chroma server.
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_SSL=false

# FastAPI port
API_PORT=8787

# Frontend API base URL (opcional; vacio => misma origin, /api)
VITE_API_URL=