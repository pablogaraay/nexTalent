# Cloud deployment reference.
# Configure these variables on the indicated Cloud Run service or job. Do not
# deploy this whole file to every component and never commit real credentials.

# Cloud Run API and Cloud Run offer-indexing job
MONGO_URI=
OLLAMA_HOST=http://VM_PRIVATE_IP:11434
CHROMA_HOST=VM_PRIVATE_IP
CHROMA_PORT=8000
CHROMA_SSL=false

# Cloud Run API only
GROQ_API_KEY=
AUTONOMOUS_AGENT_VERBOSE=false

# Cloud Run Web only
VITE_API_URL=https://API_CLOUD_RUN_URL

# GitHub Actions secrets
# - MONGO_URI: required by both data workflows.
# - GROQ_API_KEY: required by the LLM + taxonomy + mapping workflow.
# OLLAMA_HOST is defined by that workflow because Ollama runs in its own runner.
# PORT is intentionally omitted because Cloud Run injects it automatically.
